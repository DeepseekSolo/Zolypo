-- Функция проверки, активна ли игра
local function CheckGameActive()
    for _, player in ipairs(game.Players:GetPlayers()) do
        if player ~= game.Players.LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if #player.Backpack:GetChildren() > 0 or player.Character:FindFirstChildOfClass("Tool") then
                    return true
                end
            end
        end
    end
    return false
end

-- Функция для определения роли игрока
local function GetPlayerRole(player)
    if not player.Character then return "Innocent" end
    
    local character = player.Character
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return "Dead" end
    
    -- Проверка оружия в руках
    local toolInHand = character:FindFirstChildOfClass("Tool")
    if toolInHand then
        local toolName = toolInHand.Name:lower()
        if toolName:find("knife") or toolName:find("меч") or toolName:find("нож") or toolName:find("sword") then
            return "Murderer"
        end
        if toolName:find("shotgun") or toolName:find("дробовик") or toolName:find("gun") or toolName:find("пистолет") then
            return "Sheriff"
        end
    end
    
    -- Проверка инвентаря
    local backpack = player:FindFirstChildOfClass("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                local toolName = tool.Name:lower()
                if toolName:find("knife") or toolName:find("меч") or toolName:find("нож") or toolName:find("sword") then
                    return "Murderer"
                end
                if toolName:find("shotgun") or toolName:find("дробовик") or toolName:find("gun") or toolName:find("пистолет") then
                    return "Sheriff"
                end
            end
        end
    end
    
    return "Innocent"
end

-- Хранилище для Highlight объектов
local Highlights = {}

-- Функция создания Highlight для игрока
local function CreateHighlight(player)
    if Highlights[player] then
        Highlights[player]:Destroy()
        Highlights[player] = nil
    end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "MM2Highlight_" .. player.Name
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    Highlights[player] = highlight
    
    return highlight
end

-- Функция для создания ESP
local function CreateESP(player)
    if player == game.Players.LocalPlayer then return end
    
    -- Создаем BillboardGui для имен
    local espGui = Instance.new("BillboardGui")
    espGui.Name = "MM2ESP_" .. player.Name
    espGui.AlwaysOnTop = true
    espGui.Size = UDim2.new(0, 100, 0, 20)
    espGui.StudsOffset = Vector3.new(0, 2.5, 0)
    espGui.Enabled = false
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Name = "NameLabel"
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextStrokeTransparency = 0.3
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.TextSize = 14
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = espGui
    
    local lastRole = "Innocent"
    local currentHighlight = nil
    
    local function UpdateESP()
        -- Проверяем, включен ли ESP и активна ли игра
        if not ESPEnabled or not GameActive then
            espGui.Enabled = false
            if currentHighlight then
                currentHighlight.Enabled = false
            end
            return
        end
        
        if not player.Character then
            espGui.Enabled = false
            if currentHighlight then
                currentHighlight.Enabled = false
            end
            return
        end
        
        local character = player.Character
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local head = character:FindFirstChild("Head")
        
        -- Показываем только живых игроков
        if head and humanoid and humanoid.Health > 0 then
            -- Определяем роль
            local role = GetPlayerRole(player)
            
            if role ~= "Dead" then
                -- Управление Highlight
                if ShowHighlights then
                    if not currentHighlight then
                        currentHighlight = CreateHighlight(player)
                    end
                    currentHighlight.Parent = character
                    currentHighlight.Enabled = true
                    
                    -- Устанавливаем цвет Highlight в зависимости от роли
                    if role == "Murderer" then
                        currentHighlight.FillColor = Color3.fromRGB(255, 0, 0)
                        currentHighlight.OutlineColor = Color3.fromRGB(255, 100, 100)
                    elseif role == "Sheriff" then
                        currentHighlight.FillColor = Color3.fromRGB(0, 0, 255)
                        currentHighlight.OutlineColor = Color3.fromRGB(100, 100, 255)
                    elseif role == "Innocent" then
                        currentHighlight.FillColor = Color3.fromRGB(0, 255, 0)
                        currentHighlight.OutlineColor = Color3.fromRGB(100, 255, 100)
                    end
                else
                    if currentHighlight then
                        currentHighlight.Enabled = false
                    end
                end
                
                -- Управление именами
                if ShowNames then
                    espGui.Parent = head
                    espGui.Enabled = true
                    
                    -- Если включены оба режима - ники белые
                    if ShowHighlights then
                        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255) -- Белый
                    else
                        -- Иначе цветные в зависимости от роли
                        if role == "Murderer" then
                            nameLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                        elseif role == "Sheriff" then
                            nameLabel.TextColor3 = Color3.fromRGB(0, 100, 255)
                        elseif role == "Innocent" then
                            nameLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                        end
                    end
                    
                    nameLabel.Text = player.Name
                else
                    espGui.Enabled = false
                end
            else
                espGui.Enabled = false
                if currentHighlight then
                    currentHighlight.Enabled = false
                end
            end
        else
            espGui.Enabled = false
            if currentHighlight then
                currentHighlight.Enabled = false
            end
        end
    end
    
    -- Обновляем при изменении персонажа
    player.CharacterAdded:Connect(function()
        task.wait(0.5)
        if currentHighlight then
            currentHighlight:Destroy()
            currentHighlight = nil
        end
        UpdateESP()
    end)
    
    -- Обновляем при изменении в инвентаре
    player.Backpack.ChildAdded:Connect(function()
        task.wait(0.1)
        UpdateESP()
    end)
    
    player.Backpack.ChildRemoved:Connect(function()
        task.wait(0.1)
        UpdateESP()
    end)
    
    -- Обновляем каждый кадр
    game:GetService("RunService").RenderStepped:Connect(UpdateESP)
    
    -- Очистка при выходе игрока
    player.AncestryChanged:Connect(function()
        if not player.Parent then
            espGui:Destroy()
            if currentHighlight then
                currentHighlight:Destroy()
                Highlights[player] = nil
            end
        end
    end)
end

-- Мониторинг состояния игры
game:GetService("RunService").Heartbeat:Connect(function()
